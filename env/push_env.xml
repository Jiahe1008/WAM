<mujoco model="simple_push">

    <compiler angle="radian" coordinate="local"/>

    <option timestep="0.01" gravity="0 0 -9.81" integrator="RK4"/>  

    <default>
    <!-- "滑动摩擦，扭转摩擦，滚动摩擦" -->
        <geom friction="0.8 0.02 0.001"   
              solref="0.02 1"
              solimp="0.9 0.95 0.001"
              condim="3"/>
    </default>

    <worldbody>
        <!-- 灯光 -->
        <light name="main_light" pos="0 0 4" dir="0 0 -1"/>

        <!-- 固定相机，后面可视化时用 -->
        <camera name="fixed"
                pos="0 -3.2 2.4"
                xyaxes="1 0 0 0 0.65 0.76"/>

        <!-- 桌面 -->
        <geom name="table"
              type="plane"
              size="2 2 0.1"
              rgba="0.8 0.8 0.8 1"
              friction="0.8 0.02 0.001"/>

        <!-- 目标区域：只显示，不参与碰撞 -->
        <geom name="target"
              type="cylinder"
              pos="0.8 0.5 0.005"
              size="0.16 0.005"
              rgba="0.6 1.0 0.1 0.35"
              contype="0"
              conaffinity="0"/>

        <!-- 可控推杆：mocap body，位置由 Python 直接控制 -->
        <body name="pusher" mocap="true" pos="-0.7 -0.4 0.07">
            <geom name="pusher_geom"
                  type="sphere"
                  size="0.06"
                  rgba="0.1 0.3 1.0 1"
                  friction="1.0 0.02 0.001"/>
        </body>

        <!-- 被推动物体：自由圆柱 -->
        <body name="object" pos="0 0 0.05">
            <joint name="object_free" type="free"/>

            <geom name="object_geom"
                  type="cylinder"
                  size="0.08 0.05"
                  mass="0.2"
                  rgba="1.0 0.3 0.2 1"
                  friction="0.7 0.02 0.001"
                  solref="0.02 1"
                  solimp="0.9 0.95 0.001"/>
        </body>
    </worldbody>
</mujoco>